# Copy to .env for `docker compose up`. .env is git-ignored — never commit real keys.

# REQUIRED for a networked bind (docker-compose sets PP_HOST=0.0.0.0).
# Clients must send  Authorization: Bearer <this value>.
PP_API_TOKEN=change-me-to-a-long-random-string

# Provider keys pi reads from the environment (all optional — configure the ones
# you use, or add them later in the Providers UI, which persists to the volume).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional
# PP_PORT=7878
# PP_ECOSYSTEM=1
